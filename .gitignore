*.log

# Local working drafts
.issues/
.ideas/
docs/superpowers/specs/

# Claude Code sandbox bind mounts
# The sandbox enforces denyWithinAllow by creating empty read-only files
# and mounting them as ro bind mounts at protected paths. These exist only
# during Claude Code sessions and cannot be deleted (they are mount points).
/HEAD
/config
/hooks
/objects
/refs
/.bash_profile
/.bashrc
/.profile
/.zprofile
/.zshrc
/.gitconfig
/.ripgreprc
/.mcp.json

# External reference repos (submodules tracked, ignore stray zips)
*.zip

# Hooks library (separate git repo)
_hooks-lib/
