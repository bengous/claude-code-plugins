# Claude Code - track project config, ignore personal/runtime state
.claude/memory.json
.claude/settings.local.json
.claude/exports/
.claude/rebase/
.claude-version
.t-plan/
plans/
.claude-system-prompts/
.claude-system-prompt-dump.md

# Node/Bun
node_modules/
bun.lock

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDE
.vscode
.idea
*.swp
*.swo
*~

# Temp files
*.tmp
